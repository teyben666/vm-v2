# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
ADMIN_SECRET_TOKEN=

# Host API Configuration
HOST_LAN_IP=
API_PORT=8000

# Database
DATABASE_PATH=./database.sqlite

# Security
MAX_FAILED_AUTH=3
HEARTBEAT_TIMEOUT_MINUTES=3
AFK_THRESHOLD_MINUTES=60

# HTTP admin API (META:GEN or scripts). Required for GET /api/admin/vms — use a long random string.
# Leave empty to disable admin routes (503).
# VM_HTTP_ADMIN_TOKEN=

# Same machine as META:GEN: HOST_LAN_IP=127.0.0.1 — META:GEN uses VM_CONTROLLER_BASE_URL=http://127.0.0.1:8000
# Remote host: bind 0.0.0.0 and firewall; use LAN URL from META:GEN.
